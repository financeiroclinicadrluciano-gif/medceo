{
  "$schema": "https://json.schemastore.org/design-tokens.json",
  "schemaVersion": "1.0.0",
  "name": "MedCEO Nocturne",
  "description": "Espelho operacional dos tokens CSS do sistema visual MedCEO Nocturne.",
  "source": {
    "colors": "src/brand/tokens/colors.css",
    "effects": "src/brand/tokens/effects.css",
    "typography": "src/brand/tokens/typography.css",
    "spacing": "src/brand/tokens/spacing.css"
  },
  "signature": {
    "name": "Corte de Direção",
    "angle": "8deg",
    "maximumPrimaryUsesPerSection": 1
  },
  "color": {
    "primitive": {
      "obsidian": "#02070B",
      "night": "#041019",
      "navy": "#092536",
      "navy2": "#12384C",
      "navy3": "#1B4A61",
      "gold": "#CDAE58",
      "goldRgb": "205, 174, 88",
      "goldSoft": "#F0D98A",
      "bronze": "#7E6228",
      "paper": "#F4EBDD",
      "paper2": "#D8CBB5",
      "frost": "#D9E2E5",
      "ink": "#101D27",
      "muted": "#63727C",
      "success": "#2E7D5A",
      "warning": "#B8872E",
      "error": "#A85D4A",
      "info": "#2F72A8"
    },
    "semantic": {
      "surfaceDeep": "{color.primitive.night}",
      "surfaceDefault": "{color.primitive.navy}",
      "surfaceElevated": "{color.primitive.navy2}",
      "surfaceHighlight": "{color.primitive.navy3}",
      "surfaceOverlay": "rgba(2, 7, 11, 0.78)",
      "surfaceGlass": "rgba(9, 37, 54, 0.72)",
      "surfacePaper": "{color.primitive.paper}",
      "surfacePaper2": "{color.primitive.paper2}",
      "textOnDark": "{color.primitive.paper}",
      "textOnDarkSecondary": "{color.primitive.paper2}",
      "textOnDarkMuted": "rgba(244, 235, 221, 0.62)",
      "textOnLight": "{color.primitive.ink}",
      "textOnLightSecondary": "{color.primitive.muted}",
      "textAccent": "{color.primitive.gold}",
      "accent": "{color.primitive.gold}",
      "accentSoft": "{color.primitive.goldSoft}",
      "accentDeep": "{color.primitive.bronze}",
      "borderOnDark": "rgba(240, 217, 138, 0.17)",
      "borderOnDarkStrong": "rgba(240, 217, 138, 0.38)",
      "borderOnLight": "{color.primitive.paper2}",
      "borderFocus": "{color.primitive.gold}"
    },
    "component": {
      "buttonPrimaryBackground": "{color.semantic.accent}",
      "buttonPrimaryText": "{color.semantic.surfaceDefault}",
      "buttonPrimaryHover": "{color.semantic.accentSoft}",
      "inputBackground": "{color.semantic.surfaceElevated}",
      "inputBorder": "{color.semantic.borderOnDark}",
      "inputBorderFocus": "{color.semantic.borderFocus}",
      "cardBackground": "{color.semantic.surfaceElevated}",
      "navbarBackground": "{color.semantic.surfaceDeep}",
      "focusRing": "{color.semantic.borderFocus}"
    }
  },
  "typography": {
    "family": {
      "serif": "\"Playfair Display\", \"Bodoni 72\", Georgia, \"Times New Roman\", serif",
      "serifAlt": "\"Bodoni 72\", \"Playfair Display\", Georgia, serif",
      "sans": "\"Montserrat\", \"Poppins\", system-ui, Arial, sans-serif",
      "ui": "\"Poppins\", \"Montserrat\", system-ui, Arial, sans-serif",
      "mono": "\"JetBrains Mono\", \"IBM Plex Mono\", ui-monospace, monospace"
    },
    "weight": {
      "light": 300,
      "regular": 400,
      "medium": 500,
      "semibold": 600
    },
    "size": {
      "xs": "clamp(0.6875rem, 0.66rem + 0.12vw, 0.75rem)",
      "sm": "clamp(0.8125rem, 0.77rem + 0.2vw, 0.9375rem)",
      "base": "clamp(0.9375rem, 0.88rem + 0.28vw, 1.125rem)",
      "md": "clamp(1.0625rem, 0.98rem + 0.42vw, 1.3125rem)",
      "lg": "clamp(1.25rem, 1.12rem + 0.64vw, 1.625rem)",
      "xl": "clamp(1.625rem, 1.4rem + 1.08vw, 2.25rem)",
      "2xl": "clamp(2rem, 1.62rem + 1.9vw, 3.125rem)",
      "3xl": "clamp(2.75rem, 2.08rem + 3.35vw, 4.75rem)",
      "4xl": "clamp(3.75rem, 2.65rem + 5.48vw, 7rem)",
      "display": "clamp(5rem, 3.2rem + 8.8vw, 10.25rem)",
      "hero": "clamp(4rem, 2.2rem + 8vw, 9rem)",
      "jumbo": "clamp(6rem, 2rem + 18vw, 18rem)"
    },
    "lineHeight": {
      "tight": 0.96,
      "snug": 1.12,
      "normal": 1.34,
      "relaxed": 1.6
    },
    "letterSpacing": {
      "tight": "0em",
      "display": "-0.045em",
      "normal": "0.01em",
      "wide": "0.18em",
      "wider": "0.28em"
    }
  },
  "space": {
    "0": "0px",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "24px",
    "6": "32px",
    "7": "48px",
    "8": "64px",
    "9": "88px",
    "10": "112px",
    "11": "160px",
    "section": "clamp(88px, 10vw, 168px)",
    "pageX": "clamp(20px, 4vw, 64px)"
  },
  "radius": {
    "none": "0px",
    "xs": "2px",
    "sm": "4px",
    "md": "8px",
    "lg": "12px",
    "pill": "999px",
    "control": "{radius.sm}",
    "card": "{radius.md}",
    "frame": "{radius.xs}"
  },
  "border": {
    "hairline": "0.6px",
    "thin": "1px",
    "medium": "1.5px",
    "thick": "2px"
  },
  "size": {
    "iconSm": "16px",
    "iconMd": "24px",
    "iconLg": "32px",
    "touchMin": "44px",
    "container": "1280px",
    "deck": "1920px",
    "navbarHeight": "72px"
  },
  "breakpoint": {
    "sm": "480px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1440px"
  },
  "opacity": {
    "disabled": 0.4,
    "muted": 0.6,
    "subtle": 0.82,
    "hairline": 0.35
  },
  "shadow": {
    "sm": "0 1px 2px rgba(2, 7, 11, 0.28)",
    "md": "0 14px 34px rgba(2, 7, 11, 0.34)",
    "lg": "0 34px 90px rgba(2, 7, 11, 0.52)",
    "cinematic": "0 46px 120px rgba(0, 0, 0, 0.58)",
    "gold": "0 18px 52px rgba(205, 174, 88, 0.14)",
    "inset": "inset 0 1px 0 rgba(255, 255, 255, 0.12), inset 0 -1px 0 rgba(0, 0, 0, 0.28)"
  },
  "material": {
    "metal": "linear-gradient(110deg, #72571F 0%, #D3B55F 26%, #F2DF9D 46%, #A98331 70%, #E8CF7B 100%)",
    "metalSoft": "linear-gradient(110deg, rgba(126, 98, 40, 0.86), rgba(240, 217, 138, 0.98) 46%, rgba(126, 98, 40, 0.84))",
    "night": "radial-gradient(circle at 78% 4%, rgba(27, 74, 97, 0.36), transparent 38%), linear-gradient(145deg, #061720 0%, #02070B 74%)",
    "paper": "linear-gradient(145deg, rgba(255, 255, 255, 0.46), transparent 28%), linear-gradient(180deg, #F4EBDD 0%, #E9DECD 100%)",
    "glass": "linear-gradient(145deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.015) 44%, rgba(205, 174, 88, 0.045))",
    "technicalGrid": "linear-gradient(rgba(240, 217, 138, 0.045) 1px, transparent 1px), linear-gradient(90deg, rgba(240, 217, 138, 0.045) 1px, transparent 1px)",
    "scanlines": "repeating-linear-gradient(0deg, rgba(255, 255, 255, 0.018) 0 1px, transparent 1px 4px)",
    "vignette": "radial-gradient(circle at 50% 42%, transparent 36%, rgba(2, 7, 11, 0.58) 100%)",
    "decisionGlow": "radial-gradient(circle, rgba(205, 174, 88, 0.2) 0%, transparent 68%)",
    "glassBlur": "18px"
  },
  "motion": {
    "duration": {
      "fast": "150ms",
      "base": "240ms",
      "slow": "400ms",
      "editorial": "820ms"
    },
    "easing": {
      "standard": "cubic-bezier(0.4, 0, 0.2, 1)",
      "entrance": "cubic-bezier(0, 0, 0.2, 1)",
      "exit": "cubic-bezier(0.4, 0, 1, 1)",
      "premium": "cubic-bezier(0.23, 1, 0.32, 1)",
      "weighted": "cubic-bezier(0.65, 0.01, 0.05, 0.99)"
    },
    "reducedMotionDuration": "0ms"
  },
  "zIndex": {
    "base": 0,
    "raised": 10,
    "sticky": 100,
    "overlay": 1000,
    "modal": 1100,
    "toast": 1200
  }
}

